{
  "name": "@rfoerthe/killp",
  "version": "1.0.18",
  "type": "module",
  "description": "Terminate a process listening on a specific TCP port or terminate its parent process including children.",
  "main": "index.mjs",
  "bin": {
    "killp": "cli.mjs"
  },
  "scripts": {
    "example": "nodemon example.mjs",
    "postinstall": "node ./scripts/create-local-bin.mjs",
    "test": "mocha *.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rfoerthe/killp.git"
  },
  "keywords": [
    "process",
    "kill",
    "killp",
    "port",
    "parent"
  ],
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "engineStrict": true,
  "author": "Roland Förther",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/rfoerthe/killp/issues"
  },
  "homepage": "https://github.com/rfoerthe/killp#readme",
  "dependencies": {
    "ps-list": "^9.0.0",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "mocha-sinon": "^2.1.2",
    "nodemon": "^3.1.14",
    "sinon": "^21.0.3"
  },
  "overrides": {
    "diff": "^8.0.3",
    "glob": "^13.0.6",
    "serialize-javascript": "^7.0.4"
  }
}
